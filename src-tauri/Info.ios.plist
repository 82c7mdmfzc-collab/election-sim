<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Custom URL scheme for native OAuth (Apple/Google) deep-link return:
       com.playelector.app://auth-callback . Declared here because Tauri merges
       src-tauri/Info.ios.plist into the generated Info.plist on every iOS build,
       and the deep-link plugin's build.rs injection was not landing. -->
  <key>CFBundleURLTypes</key>
  <array>
    <dict>
      <key>CFBundleTypeRole</key>
      <string>Editor</string>
      <key>CFBundleURLName</key>
      <string>com.playelector.app</string>
      <key>CFBundleURLSchemes</key>
      <array>
        <string>com.playelector.app</string>
      </array>
    </dict>
  </array>
  <key>GADApplicationIdentifier</key>
  <string>ca-app-pub-5364561069734393~8538342864</string>
  <key>SKAdNetworkItems</key>
  <array>
    <dict>
      <key>SKAdNetworkIdentifier</key>
      <string>cstr6suwn9.skadnetwork</string>
    </dict>
  </array>
  <!-- Native chrome: force a light status bar (white glyphs) so it reads over the
       dark navy theme rather than the default dark-on-light. VC-based appearance is
       disabled so this global style wins (the app has a single dark theme). On
       landscape iPhone the status bar is hidden anyway; this mainly affects iPad. -->
  <key>UIStatusBarStyle</key>
  <string>UIStatusBarStyleLightContent</string>
  <key>UIViewControllerBasedStatusBarAppearance</key>
  <false/>
  <!--
    Elector is a landscape-only game (enforced in-app by OrientationGate).
    Restricting a Universal app's iPad orientations to landscape-only is
    rejected at App Store validation unless the app opts OUT of iPad
    multitasking (Split View / Slide Over), which requires all four
    orientations. UIRequiresFullScreen = true opts out, so the
    landscape-only orientation lists below are accepted.

    Tauri merges this file on top of the generated gen/apple Info.plist on
    every `tauri ios build`, so keep the native orientation policy here
    rather than as a manual Xcode target edit.
  -->
  <key>UIRequiresFullScreen</key>
  <true/>
  <key>UISupportedInterfaceOrientations</key>
  <array>
    <string>UIInterfaceOrientationLandscapeLeft</string>
    <string>UIInterfaceOrientationLandscapeRight</string>
  </array>
  <key>UISupportedInterfaceOrientations~ipad</key>
  <array>
    <string>UIInterfaceOrientationLandscapeLeft</string>
    <string>UIInterfaceOrientationLandscapeRight</string>
  </array>
</dict>
</plist>
