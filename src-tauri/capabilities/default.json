{
  "identifier": "default",
  "description": "Minimal capability set for the election simulator. Every permission NOT listed here is implicitly denied — the webview JS cannot call shell, filesystem, HTTP, clipboard, or notification APIs unless explicitly added here.",

  "windows": ["main"],

  "permissions": [
    "core:default",

    "core:app:default",

    "core:event:default",

    "core:window:allow-close",
    "core:window:allow-create",
    "core:window:allow-maximize",
    "core:window:allow-minimize",
    "core:window:allow-unmaximize",
    "core:window:allow-unminimize",
    "core:window:allow-set-focus",
    "core:window:allow-set-title",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-is-minimized",
    "core:window:allow-is-visible",
    "core:window:allow-is-fullscreen",
    "core:window:allow-set-fullscreen",
    "core:window:allow-set-resizable",
    "core:window:allow-set-size",
    "core:window:allow-inner-size",
    "core:window:allow-outer-size",
    "core:window:allow-set-min-size",

    "deep-link:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*", "app": true }, { "url": "mailto:*" }]
    },
    "elector-siwa:default",
    "elector-admob:default",
    "elector-review:default",
    "elector-push:default",
    "iap:default",
    "notification:default"

  ]
}
